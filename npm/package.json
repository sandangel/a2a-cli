{
  "name": "a2a-protocol-cli",
  "description": "A2A CLI — interact with A2A protocol agents from the terminal",
  "version": "0.0.0",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/sandangel/a2a-cli.git"
  },
  "homepage": "https://github.com/sandangel/a2a-cli",
  "bugs": {
    "url": "https://github.com/sandangel/a2a-cli/issues"
  },
  "bin": {
    "a2a": "bin.js"
  },
  "files": [
    "bin.js",
    "install.js",
    "package.json"
  ],
  "scripts": {
    "postinstall": "node install.js"
  },
  "optionalDependencies": {
    "a2a-protocol-cli-darwin-arm64": "0.0.0",
    "a2a-protocol-cli-darwin-x64": "0.0.0",
    "a2a-protocol-cli-linux-arm64": "0.0.0",
    "a2a-protocol-cli-linux-x64": "0.0.0",
    "a2a-protocol-cli-win32-x64": "0.0.0"
  },
  "engines": {
    "node": ">=18"
  },
  "preferUnplugged": true,
  "keywords": [
    "a2a",
    "agent2agent",
    "ai-agent",
    "agent-skills",
    "cli",
    "oauth2",
    "streaming",
    "rust"
  ],
  "supportedPlatforms": {
    "aarch64-apple-darwin": {
      "artifact": "a2a-aarch64-apple-darwin.tar.gz",
      "binary": "a2a"
    },
    "x86_64-apple-darwin": {
      "artifact": "a2a-x86_64-apple-darwin.tar.gz",
      "binary": "a2a"
    },
    "aarch64-unknown-linux-gnu": {
      "artifact": "a2a-aarch64-unknown-linux-gnu.tar.gz",
      "binary": "a2a"
    },
    "aarch64-unknown-linux-musl": {
      "artifact": "a2a-aarch64-unknown-linux-musl.tar.gz",
      "binary": "a2a"
    },
    "x86_64-unknown-linux-gnu": {
      "artifact": "a2a-x86_64-unknown-linux-gnu.tar.gz",
      "binary": "a2a"
    },
    "x86_64-unknown-linux-musl": {
      "artifact": "a2a-x86_64-unknown-linux-musl.tar.gz",
      "binary": "a2a"
    },
    "x86_64-pc-windows-gnu": {
      "artifact": "a2a-x86_64-pc-windows-gnu.zip",
      "binary": "a2a.exe"
    }
  }
}
