#!/usr/bin/env bash
# Update all installed skills from upstream sources, then re-mark
# .agents/skills/ as internal so they are not picked up when others
# run `npx skills add <this-repo>`.
set -euo pipefail

echo "Updating skills..."
npx skills update --yes

echo "Marking .agents/skills/ as internal..."
updated=0
for f in .agents/skills/*/SKILL.md; do
    [[ -f "$f" ]] || continue
    if ! grep -q "internal: true" "$f"; then
        perl -i -0pe 's/^(---\n(?:(?!---).)*?)(---\n)/$1metadata:\n  internal: true\n$2/sm' "$f"
        echo "  marked: $f"
        ((updated++)) || true
    fi
done

echo "Done. $updated file(s) updated."
